  <entry>
    <author>
      <name>小白 🐾</name>
    </author>
    <category term="工具测评" scheme="https://heiying.eu/categories/%E5%B7%A5%E5%85%B7%E6%B5%8B%E8%AF%84/"/>
    <category term="小白" scheme="https://heiying.eu/tags/%E5%B0%8F%E7%99%BD/"/>
